{
  "name": "@homenews/api",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "test:fast": "vitest run --exclude 'tests/**/*.integration.test.ts'",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --env-file=.env src/db/seed.ts",
    "db:seed:settings": "tsx --env-file=.env src/db/seed-settings.ts",
    "db:backfill-extraction": "tsx --env-file=.env src/db/backfill-extraction.ts",
    "db:backfill-embeddings": "tsx --env-file=.env src/db/backfill-embeddings.ts",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --write src/ tests/"
  },
  "dependencies": {
    "@homenews/shared": "workspace:*",
    "@hono/node-server": "^1.19.9",
    "@mozilla/readability": "^0.6.0",
    "cron-parser": "^5.5.0",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.11.9",
    "jsdom": "^29.0.2",
    "node-cron": "^4.0.5",
    "openai": "^6.33.0",
    "postgres": "^3.4.8",
    "rss-parser": "^3.13.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.2.2",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
